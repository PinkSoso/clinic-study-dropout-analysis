    {
      "cell_type": "code",
      "source": [
        "##Total Global participants dropout##\n",
        "\n",
        "%%sql\n",
        "SELECT DISTINCT\n",
        "COUNT(*) AS Total_participants,\n",
        "SUM(CASE WHEN Dropout_Flag = 'Yes' THEN 1 ELSE 0 END) AS nb_dropout_participants, -- dropout = 1\n",
        "ROUND(100*SUM(CASE WHEN Dropout_Flag = 'Yes' THEN 1 ELSE 0 END) / COUNT(*),2) As Dropout_rate\n",
        "FROM dropout"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
