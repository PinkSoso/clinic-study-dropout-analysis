      "source": [
        "7/ Among the complete responses (score not NULL), determine the most frequent driver for:\n",
        "- Promoters (score 9–10) → main satisfaction factor\n",
        "- Detractors (score 0–6) → main dissatisfaction factor\n",
        "- Return, for each status (Promoter and Detractor), the most cited driver and the number of occurrences."
      ],
      "metadata": {
        "id": "QM5MaZNm2htA"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# answer here\n",
        "%%sql\n",
        "\n",
        "WITH survey_with_nps AS (\n",
        "SELECT\n",
        "*,\n",
        "  CASE\n",
        "           WHEN nps_score BETWEEN 0 AND 6 THEN 'Detractor'\n",
        "           WHEN nps_score BETWEEN 7 AND 8 THEN 'Passive'\n",
        "           WHEN nps_score BETWEEN 9 AND 10 THEN 'Promoter'\n",
        "           ELSE 'None'\n",
        "           END AS nps_status\n",
        "FROM surveys\n",
        "),\n",
        "\n",
        "driver_counts AS (\n",
        "            SELECT\n",
        "            main_driver,\n",
        "            nps_status,\n",
        "            COUNT(*) AS occurences\n",
        "            FROM survey_with_nps\n",
        "            WHERE nps_score IS NOT NULL\n",
        "            AND nps_status IN ('Promoter', 'Detractor')\n",
        "            GROUP BY nps_status, main_driver\n",
        "),\n",
        "\n",
        "driver_ranked AS (\n",
        "      SELECT\n",
        "      nps_status,\n",
        "      main_driver,\n",
        "      occurences,\n",
        "      DENSE_RANK() OVER (PARTITION BY nps_status ORDER BY occurences DESC) AS Rank\n",
        "      FROM driver_counts\n",
        ")\n",
        "\n",
        "SELECT *\n",
        "FROM driver_ranked\n",
        "WHERE RANK = 1"
      ],
