      "cell_type": "code",
      "source": [
        "# answer here\n",
        "%%sql\n",
        "\n",
        "WITH survey_with_nps AS (\n",
        "SELECT\n",
        "*,\n",
        "  CASE\n",
        "           WHEN nps_score BETWEEN 0 AND 6 THEN 'Detractor'\n",
        "           WHEN nps_score BETWEEN 7 AND 8 THEN 'Passive'\n",
        "           WHEN nps_score BETWEEN 9 AND 10 THEN 'Promoter'\n",
        "           ELSE 'None'\n",
        "           END AS nps_status\n",
        "FROM surveys\n",
        "),\n",
        "\n",
        "monthly_nps AS (\n",
        "SELECT\n",
        "DATE_TRUNC('month', survey_date) AS Month,\n",
        "SUM(CASE WHEN status = 'complete' THEN 1 ELSE 0 END) AS complete_responses,\n",
        "ROUND(SUM(CASE WHEN nps_status = 'Promoter' THEN 1 ELSE 0 END) / SUM(CASE WHEN status = 'complete' THEN 1 ELSE 0 END)*100,2) AS promotion_rate,\n",
        "ROUND(SUM(CASE WHEN nps_status = 'Detractor' THEN 1 ELSE 0 END) / SUM(CASE WHEN status = 'complete' THEN 1 ELSE 0 END)*100,2) AS detractor_rate,\n",
        "ROUND(SUM(CASE WHEN nps_status = 'Promoter' THEN 1 ELSE 0 END) / SUM(CASE WHEN status = 'complete' THEN 1 ELSE 0 END)*100,2) - ROUND(SUM(CASE WHEN nps_status = 'Detractor' THEN 1 ELSE 0 END) / SUM(CASE WHEN status = 'complete' THEN 1 ELSE 0 END)*100,2) AS NPS\n",
        "FROM survey_with_nps s\n",
        "GROUP BY Month\n",
        "),\n",
        "\n",
        "Month_rate AS (\n",
        "  SELECT\n",
        "  Month,\n",
        "  NPS,\n",
        "  LAG (NPS) OVER (ORDER BY Month) AS previous_month_rate\n",
        "  FROM monthly_nps\n",
        "),\n",
        "\n",
        "Mom_change AS (\n",
        "  SELECT\n",
        "  Month,\n",
        "  NPS,\n",
        "  previous_month_rate,\n",
        "  ROUND((NPS - previous_month_rate) /NULLIF(previous_month_rate,0) *100,2) AS month_percentage\n",
        "  FROM Month_rate\n",
        ")\n",
        "\n",
        "SELECT\n",
        "*\n",
        "FROM Mom_change\n",
        "ORDER BY Month ASC\n"
      ],
